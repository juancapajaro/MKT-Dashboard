<!-- CSV UPLOAD EVENT LISTENERS -->
<script>
document.getElementById("csvDropZone").addEventListener("dragover", function(e) {
  e.preventDefault();
  this.classList.add("drag-over");
});
document.getElementById("csvDropZone").addEventListener("dragleave", function() {
  this.classList.remove("drag-over");
});
document.getElementById("csvDropZone").addEventListener("drop", handleDrop);
document.getElementById("csvDropZone").addEventListener("click", function() {
  document.getElementById("csvFileInput").click();
});
document.getElementById("csvDropZone").addEventListener("keydown", function(e) {
  if (e.key === "Enter" || e.key === " ") {
    e.preventDefault();
    document.getElementById("csvFileInput").click();
  }
});
</script>

<!-- MODULE SCRIPTS -->
<script src="csv-parser.js"></script>
<script src="charts.js"></script>
<script src="ui.js"></script>

</body>
</html>
