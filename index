<!DOCTYPE html>
<html lang="es" class="theme-dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard Marketing — Barbarenas</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="styles.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.7/dist/chart.umd.min.js"></script>
  <script>if(typeof Chart!=="undefined")Chart.defaults.animation=false;</script>
  <script src="https://cdn.jsdelivr.net/npm/html-to-image@1.11.11/dist/html-to-image.js"></script>
</head>
<body>

<div class="viz-menu">
  <button class="vm-btn" onclick="toggleMenu()" aria-label="Menú de opciones">
    <svg width="17" height="17" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
      <line x1="3" y1="5" x2="17" y2="5"/><line x1="3" y1="10" x2="17" y2="10"/><line x1="3" y1="15" x2="17" y2="15"/>
    </svg>
  </button>
  <div class="vm-drop" id="vmDrop" role="menu">
    <button onclick="cycleTheme()" role="menuitem"><span id="themeIco">🌙</span><span id="themeLbl">Dark</span></button>
    <button onclick="dlImage()" role="menuitem"><span>📥</span><span>Descargar PNG</span></button>
    <button onclick="window.print()" role="menuitem"><span>🖨️</span><span>Imprimir / PDF</span></button>
  </div>
</div>

<main>
  <header class="header an d1">
    <div class="header-left">
      <div class="logo-wrap">
        <img src="data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAKAAAACgCAIAAAAErfB6AAABCGlDQ1BJQ0MgUHJvZmlsZQAAeJxjYGA8wQAELAYMDLl5JUVB7k4KEZFRCuwPGBiBEAwSk4sLGHADoKpv1yBqL+viUYcLcKakFicD6Q9ArFI[...]" alt="Barbarenas logo">
      </div>
      <div class="header-title">
        <h1>Marketing Dashboard</h1>
        <p>Barbarenas · Eco Retreat · Puerto Escondido, Oaxaca</p>
      </div>
    </div>
    <div class="date-bar">
      <label for="selFrom">Período:</label>
      <select id="selFrom" onchange="applyFilter()" aria-label="Fecha de inicio">
        <option value="2025-03">Marzo 2025</option>
        <option value="2025-04">Abril 2025</option>
        <option value="2025-05" selected>Mayo 2025</option>
      </select>
      <span class="sep">→</span>
      <select id="selTo" onchange="applyFilter()" aria-label="Fecha de fin">
        <option value="2025-03">Marzo 2025</option>
        <option value="2025-04">Abril 2025</option>
        <option value="2025-05" selected>Mayo 2025</option>
      </select>
      <span class="period-pill"><span class="period-dot"></span><span id="periodLbl">Abr → May</span></span>
    </div>
  </header>

  <!-- CSV UPLOAD ZONE -->
  <div class="csv-banner an d2">
    <div class="csv-drop-zone" id="csvDropZone" role="button" tabindex="0" aria-label="Zona de carga de archivo CSV">
      <div class="csv-drop-left">
        <div class="csv-icon">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/>
            <polyline points="9 15 12 12 15 15"/>
          </svg>
        </div>
        <div class="csv-text">
          <strong>Actualizar datos</strong> — arrastrá tu CSV aquí o hacé clic para seleccionar
        </div>
      </div>
      <button class="csv-btn" onclick="event.stopPropagation();document.getElementById('csvFileInput').click()" aria-label="Cargar archivo CSV">
        Cargar CSV
      </button>
    </div>
    <div class="csv-status" id="csvStatus"></div>
    <input type="file" id="csvFileInput" accept=".csv" onchange="handleCSV(this.files[0])">
  </div>

  <div class="hdivider"></div>

  <div class="tab-bar an d3" role="tablist">
    <button class="tab-btn active" onclick="showTab('resumen',this)" role="tab" aria-selected="true">Resumen mensual</button>
    <button class="tab-btn" onclick="showTab('diario',this)" role="tab" aria-selected="false">Registro diario</button>
    <button class="tab-btn" onclick="showTab('posts',this)" role="tab" aria-selected="false">Posts &amp; métricas</button>
  </div>

  <!-- TAB RESUMEN -->
  <div class="tab-section active container" id="tab-resumen" role="tabpanel">
    <div class="kpi-grid">
      <div class="kpi an d1"><div class="kpi-label">Total Posts</div>
        <div class="kpi-value ac" id="kv-posts">—</div><div class="kpi-sub" id="ks-posts">—</div></div>
      <div class="kpi an d2"><div class="kpi-label">Total Views</div>
        <div class="kpi-value" id="kv-views">—</div><div class="kpi-sub">Total al mes / D1 desde mayo</div></div>
      <div class="kpi an d3"><div class="kpi-label">Total Likes</div>
        <div class="kpi-value" id="kv-likes">—</div><div class="kpi-sub">Acumulado período</div></div>
      <div class="kpi an d4"><div class="kpi-label">Nuevos Seguidores</div>
        <div class="kpi-value go" id="kv-followers">—</div><div class="kpi-sub">Registro diario</div></div>
      <div class="kpi an d5"><div class="kpi-label">Total Saves</div>
        <div class="kpi-value" id="kv-saves">—</div><div class="kpi-sub">Acumulado período</div></div>
      <div class="kpi an d6"><div class="kpi-label">Stories registradas</div>
        <div class="kpi-value" id="kv-stories">—</div><div class="kpi-sub">Historias contadas</div></div>
    </div>

    <div class="info-box an d3">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12" y2="20"/><circle cx="12" cy="4" r="1"/></svg>
      <div><strong>Contexto de métricas:</strong> Posts anteriores al <strong>5 de mayo 2025</strong> muestran el <strong>total acumulado al mes del posteo</strong>. A partir del post <em>Community</em> (5-May): registramos <strong>D1 · D3 · D7</strong> por separado.</div>
    </div>

    <div class="chart-grid rev">
      <div class="chart-card"><div class="chart-title">Posts por mes</div>
        <div class="chart-sub">Publicaciones en el período seleccionado</div>
        <div class="cw"><canvas id="cMonthPosts" aria-label="Gráfico de posts por mes"></canvas></div></div>
      <div class="chart-card"><div class="chart-title">Views totales por mes</div>
        <div class="chart-sub">Total al mes (pre-mayo) · D1 desde mayo</div>
        <div class="cw"><canvas id="cMonthViews" aria-label="Gráfico de views totales por mes"></canvas></div></div>
    </div>

    <div class="chart-card rev" style="margin-bottom:20px;">
      <div class="chart-title">Engagement por mes — Likes · Shared · Saves · Comments</div>
      <div class="chart-sub">Acumulado por mes</div>
      <div class="legend">
        <div class="legend-item"><div class="ld" style="background:#7d9c6e"></div>Likes</div>
        <div class="legend-item"><div class="ld" style="background:#c4a96b"></div>Shared</div>
        <div class="legend-item"><div class="ld" style="background:#a07090"></div>Saves</div>
        <div class="legend-item"><div class="ld" style="background:#6090a0"></div>Comments</div>
      </div>
      <div class="cw-tall"><canvas id="cMonthMetrics" aria-label="Gráfico de engagement por mes"></canvas></div>
    </div>

    <div class="card rev">
      <p class="sec-head">Tabla comparativa mensual</p>
      <div class="tbl-wrap"><table>
        <thead><tr><th>Mes</th><th>Posts</th><th>Stories</th><th>Seguidores +</th><th>Views</th><th>Likes</th><th>Saves</th><th>Estado</th></tr></thead>
        <tbody id="monthly-tbody"></tbody>
      </table></div>
    </div>
  </div>

  <!-- TAB DIARIO -->
  <div class="tab-section container" id="tab-diario" role="tabpanel">
    <div id="daily-content">
      <div class="chart-card" style="margin-bottom:18px;">
        <div class="chart-title">Stories por día — Abril 2025</div>
        <div class="chart-sub">Historias publicadas cada día</div>
        <div class="cw-tall"><canvas id="cStoriesApr" aria-label="Gráfico de stories por día en abril"></canvas></div>
      </div>
      <div class="chart-card" style="margin-bottom:18px;">
        <div class="chart-title">Stories por día — Mayo 2025</div>
        <div class="chart-sub">Datos hasta el día 8</div>
        <div class="cw"><canvas id="cStoriesMay" aria-label="Gráfico de stories por día en mayo"></canvas></div>
      </div>
      <div class="chart-card">
        <div class="chart-title">Nuevos seguidores por día — Abril &amp; Mayo</div>
        <div class="chart-sub">Seguidores ganados por día registrado</div>
        <div class="cw-tall"><canvas id="cFollowersDaily" aria-label="Gráfico de nuevos seguidores por día"></canvas></div>
      </div>
    </div>
    <div class="no-data" id="daily-nodata" style="display:none">No hay datos diarios para el período seleccionado.</div>
  </div>

  <!-- TAB POSTS -->
  <div class="tab-section container" id="tab-posts" role="tabpanel">
    <div class="info-box" style="margin-bottom:14px;">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12" y2="20"/><circle cx="12" cy="4" r="1"/></svg>
      <div>Posts antes del <strong>5-May-2025</strong>: métricas = <strong>total acumulado al mes</strong>. Desde <em>Community</em> (5-May): registramos <strong>D1 · D3 · D7</strong> por separado.</div>
    </div>
    <fieldset class="day-toggle" style="border:none;padding:0;margin:0;">
      <legend style="display:none;">Seleccionar métrica por días</legend>
      <span class="day-lbl">Métricas:</span>
      <button class="day-btn active" onclick="setDay('D1',this)">D1 — Día 1</button>
      <button class="day-btn" onclick="setDay('D3',this)">D3 — Día 3</button>
      <button class="day-btn" onclick="setDay('D7',this)">D7 — Día 7</button>
    </fieldset>

    <div class="chart-card rev" style="margin-bottom:16px;">
      <div class="chart-title" id="ct-views">Views por post — D1 / Total al mes</div>
      <div class="chart-sub">Reels en verde · Posts en dorado</div>
      <div class="legend">
        <div class="legend-item"><div class="ld" style="background:#7d9c6e"></div>Reel</div>
        <div class="legend-item"><div class="ld" style="background:#c4a96b"></div>Post</div>
      </div>
      <div class="cw-tall"><canvas id="cPostViews" aria-label="Gráfico de views por post"></canvas></div>
    </div>

    <div class="chart-grid rev" style="margin-bottom:16px;">
      <div class="chart-card"><div class="chart-title" id="ct-likes">Likes por post</div>
        <div class="cw"><canvas id="cPostLikes" aria-label="Gráfico de likes por post"></canvas></div></div>
      <div class="chart-card"><div class="chart-title" id="ct-saves">Saves por post</div>
        <div class="cw"><canvas id="cPostSaves" aria-label="Gráfico de saves por post"></canvas></div></div>
    </div>

    <div class="card rev">
      <p class="sec-head" id="tt-posts">Todos los posts — D1 / Total al mes</p>
      <div class="tbl-wrap"><table>
        <thead><tr><th>Fecha</th><th>Tipo</th><th>Tema</th>
          <th>Views</th><th>Likes</th><th>Comments</th><th>Shared</th><th>Saves</th>
          <th>Fuente</th></tr></thead>
        <tbody id="posts-tbody"></tbody>
      </table></div>
    </div>
  </div>
</main>

